# Contains mutation testing data
**/mutants.out*/

# Environment and secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Database
*.db
*.sqlite

# Coverage
coverage/
*.lcov

# Documentation build
docs/book/

# Research notes (not part of codebase)
aura-research/
