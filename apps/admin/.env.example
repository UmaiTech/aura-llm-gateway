# Aura Admin Dashboard Environment Configuration
# Copy this file to .env and update the values

# Gateway API URL (required)
# The URL where your Aura LLM Gateway is running
#   - Local dev:        http://localhost:8080
#   - Production:       https://api.aura-llm.dev
# In production this is wired through Vercel project env vars
# (Settings > Environment Variables on the aura-llm-gateway project)
# — do NOT bake a prod URL into a committed .env file.
VITE_API_BASE_URL=http://localhost:8080

# Admin key for authentication (optional — DEV ONLY)
# If set, will auto-fill the login form in development mode.
# This should match the AURA_ADMIN_KEY set on the gateway server.
# NEVER set this in production — it would auto-fill the login screen
# with a hardcoded key visible in client-side bundles.
# VITE_ADMIN_KEY=your-admin-key-here
