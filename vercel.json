{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install && cd apps/landing && npm install && npm run build && cd ../chat && npm install && npm run build && cd ../.. && mkdir -p apps/landing/dist/playground && cp -R apps/chat/dist/. apps/landing/dist/playground/",
  "outputDirectory": "apps/landing/dist",
  "installCommand": "echo 'install handled in buildCommand'",
  "framework": null,
  "functions": {
    "api/**/*.mts": {
      "runtime": "@vercel/node@5.0.0"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/playground/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(svg|png|jpg|jpeg|gif|webp|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "playground.aura-llm.dev" }],
      "destination": "/chat",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/[...all]"
    },
    {
      "source": "/api/proxy/:path*",
      "destination": "/api/proxy/[...path]"
    },
    {
      "source": "/((?!playground/|api/).*)",
      "has": [{ "type": "host", "value": "playground.aura-llm.dev" }],
      "destination": "/playground/$1"
    },
    {
      "source": "/playground/((?!assets/|.*\\..*).*)",
      "destination": "/playground/index.html"
    },
    {
      "source": "/((?!playground/|api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
