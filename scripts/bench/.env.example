# Provider — the ONLY upstream LLM. Every gateway routes to this.
ANTHROPIC_API_KEY=sk-ant-...

# Per-gateway API keys (leave blank to skip that gateway)
AURA_KEY=
AURA_HOSTED_KEY=
BIFROST_KEY=
HELICONE_KEY=
LITELLM_KEY=
OPENROUTER_KEY=
PORTKEY_KEY=

# Per-gateway base URLs (override defaults if needed)
AURA_URL=http://localhost:8080
# AURA_HOSTED_URL=https://api.aura-llm.dev
# BIFROST_URL=http://localhost:8081
# HELICONE_URL=https://oai.helicone.ai
# LITELLM_URL=http://localhost:4000
# OPENROUTER_URL=https://openrouter.ai/api
# PORTKEY_URL=https://api.portkey.ai
